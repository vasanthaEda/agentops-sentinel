# Copy to .env and adjust as needed. Every variable has a safe, offline
# default (see src/agentops_sentinel/config.py) -- you do not need any of
# these set to run the app or the test suite.

# --- LLM provider -----------------------------------------------------------
# "fake" (default, offline/deterministic), "anthropic", or "openai".
# Falls back to "fake" automatically if the matching API key isn't set.
AGENTOPS_LLM_PROVIDER=fake
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
AGENTOPS_ANTHROPIC_MODEL=claude-3-5-haiku-latest
AGENTOPS_OPENAI_MODEL=gpt-4o-mini

# --- Guardrails --------------------------------------------------------------
AGENTOPS_MAX_STEPS=6
AGENTOPS_MAX_RETRIES_PER_TASK=2
AGENTOPS_BUDGET_USD=0.50
AGENTOPS_STEP_TIMEOUT_S=8.0
AGENTOPS_CONFIDENCE_THRESHOLD=0.6
AGENTOPS_COST_PER_LLM_CALL=0.03
AGENTOPS_COST_PER_TOOL_CALL=0.01

# --- Storage -------------------------------------------------------------
# Leave empty to use the in-memory session store.
AGENTOPS_REDIS_URL=

# --- Tracing -----------------------------------------------------------------
AGENTOPS_OTEL_CONSOLE_EXPORT=false
AGENTOPS_SERVICE_NAME=agentops-sentinel
